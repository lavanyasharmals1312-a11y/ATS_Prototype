# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg://ats_user:ats_password@localhost:5432/proex_ats

# ── Security ──────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-real-secret-key-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── File Storage ──────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# ── AI Parsing (optional) ────────────────────────────────────
ENABLE_AI_PARSING=false
GEMINI_API_KEY=

# ── Application ───────────────────────────────────────────────
APP_ENV=development
CORS_ORIGINS=http://localhost:5173
LOG_LEVEL=INFO
APP_VERSION=1.0.0
